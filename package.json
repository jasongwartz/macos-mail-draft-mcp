{
  "name": "macos-mail-draft-mcp",
  "version": "0.1.0",
  "description": "MCP server that creates drafts in macOS Mail.app via AppleScript, with attachment support",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "macos-mail-draft-mcp": "src/index.ts"
  },
  "files": [
    "src"
  ],
  "engines": {
    "node": ">=24"
  },
  "os": [
    "darwin"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "keywords": [
    "mcp",
    "macos",
    "mail",
    "applescript",
    "draft"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
